[run]
branch = True
omit =
    # MCP tool modules — require optional deps or full server context
    arkana/mcp/tools_*.py
    arkana/mcp/server.py
    arkana/mcp/_angr_helpers.py
    arkana/mcp/_bsim_features.py
    # Parsers requiring optional heavy deps
    arkana/parsers/capa.py
    arkana/parsers/floss.py
    arkana/parsers/pe.py
    arkana/parsers/signatures.py
    # Config (mostly optional-import availability checks)
    arkana/config.py
    # Server/CLI entry points (integration, not unit-tested)
    arkana/__main__.py
    arkana/main.py
    arkana/cli/*
    arkana/background.py
    arkana/resources.py
    # Dashboard — requires running server context (tested via integration tests)
    arkana/dashboard/app.py

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING
    raise NotImplementedError
